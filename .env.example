# Adaptive Cache Invalidation System — Environment Configuration
# Copy this to .env and adjust values for your environment

# Project paths (relative to project root)
PROJECT_ROOT=.
DATA_DIR=shared_db
RESULTS_DIR=results
PLOTS_DIR=plots
LOG_DIR=logs

# Docker
DOCKER_NETWORK=cache_net
COMPOSE_FILE=docker-compose.yml

# Node configuration
NODE_A_PORT=5001
NODE_B_PORT=5002
NODE_C_PORT=5003

# Redis configuration
REDIS_A_PORT=6379
REDIS_B_PORT=6380
REDIS_C_PORT=6381
REDIS_PORT_INTERNAL=6379

# Database
DB_PATH=/data/cache.db
CACHE_TTL=10

# Load generator defaults
WRITE_RATE=10
READ_RATE=100
DURATION=60
KEY_SPACE=100

# Controller thresholds
HIGH_THRESHOLD=50
LOW_THRESHOLD=10
CONTROLLER_INTERVAL=3
WRITE_WINDOW=5

# Batch strategy
BATCH_INTERVAL=2.5

# Feature flags
IS_WRITER=false
RUN_CONTROLLER=false

# Logging
LOG_LEVEL=INFO
